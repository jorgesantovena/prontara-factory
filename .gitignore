# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
# H3-ARQ-04: Playwright reports
/playwright-report
/test-results
/.playwright

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# backups — ver docs/retention-policy.md
*.bak
*.bak-*
/backups/
/_audit/archive/

# legacy persistence — sustituido por data/factory/active-client.json
/.prontara/current-client.txt

# runtime data en modo filesystem (modo dev / demo offline).
# Contiene cuentas tenant, hashes de contraseña, audit logs, mail
# outbox con tokens de reset, eventos de dominio con payment_intent_ids,
# uploads de Factory Chat, snapshots, etc. NO debe subir a git nunca.
/data/

# Prisma generated client (se regenera con prisma generate)
/prisma/generated/

# auditorías internas y snapshots de bloques de migración — solo locales
/_audit/
/.prontara/

# residual deprecado: Supabase (sustituido por Neon Postgres + Prisma)
/supabase/
