// Schema de Prontara Factory.
//
// Modelo dual de persistencia: en local todo vive en JSON (rápido para dev,
// fácil de inspeccionar). En producción (Vercel + Neon) vive en Postgres.
// El switch lo controla la variable PRONTARA_PERSISTENCE = "postgres" | "filesystem".
// Default filesystem para no romper nada hasta que se ejecute el seed.
//
// Convenciones:
//   - Identidad pública del tenant: campo `clientId` (lo usa el runtime en URLs).
//   - Todos los modelos operativos tienen `clientId` + índice compuesto para
//     aislar consultas por tenant.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Tenant + Cuentas (lo que hoy vive en .prontara/clients/*.json y data/saas/accounts/*.json)
// ===========================================================================

model Tenant {
  id              String   @id @default(cuid())
  /// id público que el runtime usa en URLs (ej: estandar-20260419194129).
  clientId        String   @unique
  slug            String   @unique
  /// identificador legacy en código antiguo. Mantener por compatibilidad.
  legacyTenantId  String?  @unique
  displayName     String
  shortName       String?
  sector          String?
  businessType    String?
  companySize     String?
  blueprintVersion String?
  /// JSON arbitrario con la definición completa del tenant (branding,
  /// modules, sampleData, etc.). Mientras no se modelen sub-entidades,
  /// volcamos aquí lo que vive en .prontara/clients/<id>.json.
  definition      Json     @default("{}")
  /// Branding sobreentendido (extraído de definition para queries rápidas).
  brandingJson    Json     @default("{}")
  status          String   @default("provisioning")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts            TenantAccount[]
  subscriptions       BillingSubscription[]
  trial               TrialState?
  onboardings         OnboardingState[]
  lifecycle           LifecycleState?
  moduleData          TenantModuleRecord[]
  sequenceCounters    TenantSequenceCounter[]
  evolutionEvents     EvolutionEvent[]
  auditEvents         AuditEvent[]

  @@index([status])
  @@index([businessType])
}

model TenantAccount {
  id                  String   @id
  tenantId            String
  clientId            String
  slug                String
  email               String
  fullName            String
  role                String   /// owner | admin | manager | staff
  status              String   /// pending | active | disabled
  passwordHash        String   /// scrypt$N$r$p$salt$hash
  temporaryPassword   String   @default("")
  mustChangePassword  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastProvisionedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([clientId, email])
  @@index([clientId, status])
}

// ===========================================================================
// Billing: subscriptions + invoices (data/saas/billing/*.json)
// ===========================================================================

model BillingSubscription {
  id                       String   @id @default(cuid())
  tenantId                 String
  clientId                 String   @unique
  slug                     String
  displayName              String
  billingEmail             String
  currentPlanKey           String   /// trial | basico | estandar | premium
  status                   String
  autoRenew                Boolean  @default(true)
  seats                    Int      @default(2)
  setupFeePaidCents        Int      @default(0)
  concurrentUsersBilled    Int      @default(1)
  supportActive            Boolean  @default(false)
  renewsAt                 DateTime
  cancelAt                 DateTime?
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  lastCheckoutIntent       Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices BillingInvoice[]

  @@index([status])
  @@index([currentPlanKey])
}

model BillingInvoice {
  id                       String   @id
  subscriptionId           String
  tenantId                 String
  clientId                 String
  slug                     String
  planKey                  String
  concept                  String
  amountCents              Int
  currency                 String   @default("EUR")
  status                   String   /// issued | paid | void
  stripeCheckoutSessionId  String?
  stripeSubscriptionId     String?
  createdAt                DateTime @default(now())

  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([status])
}

// ===========================================================================
// Trial / Onboarding / Lifecycle
// ===========================================================================

model TrialState {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  clientId      String   @unique
  slug          String
  status        String   /// active | expired
  trialDays     Int      @default(14)
  daysRemaining Int      @default(14)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  expiresAt     DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model OnboardingState {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  slug        String
  accountId   String
  stepsJson   Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([clientId, accountId])
}

model LifecycleState {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  clientId    String   @unique
  sentJson    Json     @default("[]")
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ===========================================================================
// Vertical overrides
// ===========================================================================

model VerticalOverride {
  id           String   @id @default(cuid())
  packKey      String   @unique
  payloadJson  Json
  updatedAt    DateTime @updatedAt
  updatedBy    String?

  @@index([updatedAt])
}

// ===========================================================================
// Leads del formulario público
// ===========================================================================

model Lead {
  id              String   @id
  name            String
  email           String
  company         String   @default("")
  phone           String   @default("")
  message         String   @default("")
  sourceVertical  String?
  status          String   @default("new")
  userAgent       String   @default("")
  ip              String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

// ===========================================================================
// Datos operativos del ERP (registros de cada módulo)
// ===========================================================================

model TenantModuleRecord {
  id          String   @id
  tenantId    String
  clientId    String
  moduleKey   String
  payloadJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clientId, moduleKey, updatedAt])
  @@index([clientId, moduleKey, id])
  // H3-ARQ-03: índice compuesto para búsquedas por createdAt
  @@index([clientId, moduleKey, createdAt])
}

// ===========================================================================
// Permisos granulares por rol + módulo + acción (H2-PERM).
//
// Cada fila representa una restricción/permiso explícito. Si no existe
// fila para (clientId, role, moduleKey), se aplica el default global
// del helper. Las filas customizan el default.
// ===========================================================================

model TenantPermissionPolicy {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  role        String   /// owner | admin | manager | staff | clienteFinal | docente | familia | estudiante
  moduleKey   String
  /// CSV de acciones permitidas: view,create,edit,delete,approve,export
  actionsCsv  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clientId, role, moduleKey])
  @@index([clientId, role])
}

// ===========================================================================
// SSO — vínculos OAuth de cuentas con proveedores externos (H2-SSO).
// ===========================================================================

model TenantAccountSSO {
  id           String   @id @default(cuid())
  accountId    String
  provider     String   /// google | microsoft
  providerSub  String   /// "sub" del id_token (identificador único del usuario en el proveedor)
  email        String   /// email tal como llegó del proveedor (auditoría)
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?

  @@unique([provider, providerSub])
  @@index([accountId])
}

// ===========================================================================
// MFA TOTP (DEV-MFA) — segundo factor de autenticación por cuenta.
//
// Cuando una cuenta activa MFA, en cada login se le pide código TOTP de
// 6 dígitos (Google Authenticator o equivalente). Los backupCodes son
// para recuperar acceso si pierde el dispositivo — cada uno es de un
// solo uso (consumedAt no null).
// ===========================================================================

model TenantAccountMfa {
  id              String   @id @default(cuid())
  accountId       String   @unique
  /// Secret en Base32 — visible para que el usuario lo escanee al activar.
  /// En producción debería cifrarse con PRONTARA_SESSION_SECRET, hoy en claro
  /// por simplicidad MVP — TODO: cifrar antes de prod-prod.
  secret          String
  enabled         Boolean  @default(false)
  /// Códigos de respaldo en formato JSON: [{ code, consumedAt? }, ...]
  backupCodesJson Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  enabledAt       DateTime?
}

// ===========================================================================
// Workflow rules (DEV-WF) — reglas configurables por tenant.
// ===========================================================================

model WorkflowRule {
  id           String   @id @default(cuid())
  tenantId     String
  clientId     String
  name         String
  /// Módulo que dispara la regla (clientes, proyectos, tareas, etc.)
  triggerModule String
  /// Estado al que tiene que cambiar el registro para disparar (vacío = cualquier creación)
  triggerEstado String?
  /// Tipo de acción: notify | createTask | setEstado
  actionType   String
  /// Payload JSON con detalles de la acción
  actionPayload Json
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId, triggerModule, enabled])
}

// ===========================================================================
// Custom fields (DEV-CF) — campos personalizados por tenant.
// ===========================================================================

model TenantCustomField {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  moduleKey   String
  fieldKey    String
  label       String
  kind        String   /// text | email | tel | textarea | date | number | money | status
  required    Boolean  @default(false)
  placeholder String?
  /// Para kind=status, opciones JSON: [{ value, label }, ...]
  optionsJson Json?
  /// Posición relativa entre los campos del módulo (0=primero)
  position    Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clientId, moduleKey, fieldKey])
  @@index([clientId, moduleKey])
}

// ===========================================================================
// Reportes guardados (DEV-REP) — constructor de reportes por tenant.
// ===========================================================================

model TenantReport {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  name        String
  description String?
  /// Módulo de origen
  moduleKey   String
  /// Columnas a mostrar en orden — array de fieldKey
  columnsJson Json     @default("[]")
  /// Filtros — array de { field, operator, value }
  filtersJson Json     @default("[]")
  /// Campo por el que agrupar (opcional)
  groupBy     String?
  /// Tipo de gráfico: none | bar | line | pie
  chartType   String   @default("none")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId, moduleKey])
}

// ===========================================================================
// Verifactu / AEAT — registro de envíos (SF-12, stub).
//
// Cada factura emitida desde el módulo "facturacion" puede generar un
// VerifactuSubmission cuando el operador pulsa "Verifactu" en la fila.
// El registro guarda el XML preparado, el estado del envío y, cuando
// AEAT responda, el CSV/huella y los datos del QR para insertar en el
// PDF de la factura.
//
// status:
//   - prepared: payload generado, pendiente de firmar y enviar
//   - sent:     enviado a AEAT, respuesta OK con CSV
//   - error:    fallo al enviar — errorMsg con detalle
//
// La firma XML-DSig y el envío al web service AEAT son trabajo de
// integración real (requieren certificado de la sociedad). Hoy el flujo
// llega hasta status="prepared" y deja el resto como TODO documentado
// en docs/verifactu-pendientes.md.
// ===========================================================================

model VerifactuSubmission {
  id                     String   @id @default(cuid())
  tenantId               String
  clientId               String
  /// id del registro en el módulo "facturacion" (TenantModuleRecord.id)
  facturaModuleRecordId  String
  /// número de factura visible (ej. FAC-2026-001), copiado para auditoría
  facturaNumero          String
  status                 String   /// prepared | sent | error
  xmlPayload             String   /// XML preparado (sin firmar). En postgres es text.
  csvHuella              String?  /// CSV devuelto por AEAT cuando status=sent
  qrPayload              String?  /// URL/contenido para QR a embeber en PDF
  errorMsg               String?
  createdAt              DateTime @default(now())
  sentAt                 DateTime?

  @@index([clientId, createdAt])
  @@index([facturaModuleRecordId])
  @@index([status, createdAt])
}

// ===========================================================================
// Numeración correlativa por tenant + año (SF-01)
//
// Mantiene contadores correlativos para facturas, presupuestos y
// justificantes (y cualquier secuencia futura). Una fila por
// (clientId, sequenceKey, year). El campo `lastNumber` se incrementa
// atómicamente vía upsert con `increment`, garantizando que dos
// peticiones concurrentes nunca obtengan el mismo número.
//
// Formato del número final renderizado: `${prefix}-${year}-${num.padStart(3,'0')}`
// (ej: FAC-2026-001, PRES-2026-014, JUS-2026-007). El prefijo se
// guarda aquí solo como referencia auditable — la lógica de formato
// vive en `src/lib/persistence/sequence-counter-async.ts`.
// ===========================================================================

model TenantSequenceCounter {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  sequenceKey String   /// "facturas" | "presupuestos" | "justificantes"
  year        Int
  prefix      String   /// "FAC" | "PRES" | "JUS"
  lastNumber  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([clientId, sequenceKey, year])
  @@index([clientId, sequenceKey])
}

// ===========================================================================
// Trazas
// ===========================================================================

model EvolutionEvent {
  id          String   @id @default(cuid())
  tenantId    String
  kind        String
  payloadJson Json
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model AuditEvent {
  id              String   @id @default(cuid())
  tenantId        String?
  conversationId  String?
  actorEmail      String?
  tool            String
  outcome         String
  durationMs      Int      @default(0)
  inputJson       Json?
  resultJson      Json?
  touchedPaths    String[]
  backupRef       String?
  errorMessage    String?
  createdAt       DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tool, createdAt])
  @@index([actorEmail, createdAt])
  @@index([conversationId])
  // H3-ARQ-03: índice por tenant + createdAt para limpieza por retención.
  @@index([tenantId, createdAt])
}

// =====================================================================
// StripeProcessedEvent — dedupe de eventos del webhook Stripe.
//
// Stripe reintenta el webhook si no responde 200 antes de 30s, hasta 3
// días. Para garantizar exactly-once procesamiento (no duplicar
// activaciones de plan, dobles facturas, etc.) guardamos el event.id de
// cada evento procesado y lo rechazamos si llega de nuevo.
// =====================================================================
model StripeProcessedEvent {
  eventId     String   @id // El id del evento Stripe (ej: evt_1ABC123...)
  type        String   // checkout.session.completed, invoice.paid, etc.
  processedAt DateTime @default(now())
  outcome     String   // ok | error | duplicate
  errorMsg    String?  // Si outcome=error, mensaje breve

  @@index([type, processedAt])
}

// =====================================================================
// DomainEvent — saga / cola de eventos de dominio para reintentos y
// compensación (ARQ-7).
//
// Patrón: cuando un paso del pipeline falla más allá de lo que el
// retry síncrono puede absorber (o cuando queremos disparar una
// compensación como un refund Stripe), emitimos un DomainEvent en
// estado pending. Un cron en Vercel (`/api/cron/process-domain-events`)
// los procesa con backoff exponencial y los marca completed o
// dead_letter. Los handlers viven en domain-event-handlers.ts.
//
// El uso inicial es la compensación post-pago: si activatePaidPlanAsync
// falla tras N reintentos del webhook Stripe, emitimos
// "tenant.activation.failed" cuyo handler ejecuta el refund.
// =====================================================================
model DomainEvent {
  id            String    @id @default(cuid())
  type          String    // ej: "tenant.activation.failed"
  aggregateType String    // ej: "tenant", "subscription"
  aggregateId   String    // id del agregado afectado
  payload       Json      // datos arbitrarios para el handler
  status        String    // pending | processing | completed | dead_letter
  retryCount    Int       @default(0)
  maxRetries    Int       @default(5)
  occurredAt    DateTime  @default(now())
  nextAttemptAt DateTime  @default(now())
  processedAt   DateTime?
  errorMsg      String?

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@index([type, occurredAt])
}

// =====================================================================
// FactoryChatConversation + FactoryChatMessage — persistencia del chat
// del operador en /factory/chat.
//
// Cada operador (cuenta Factory) tiene N conversaciones. Cada conversación
// tiene una lista append-only de mensajes (user/assistant/tool). Los
// adjuntos (imágenes, docs) se guardan como referencias JSON en el
// campo `attachmentsJson` del mensaje — los binarios viven en /api/factory/chat/uploads.
//
// Reemplaza el storage filesystem de data/factory/chat/<accountId>/*.jsonl
// para que el chat funcione en serverless (Vercel) sin filesystem persistente.
// =====================================================================
model FactoryChatConversation {
  id           String   @id
  accountId    String
  title        String
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages FactoryChatMessage[]

  @@index([accountId, updatedAt])
}

model FactoryChatMessage {
  id              String   @id
  conversationId  String
  role            String   // user | assistant | tool
  content         String   /// texto del mensaje (en role=tool es JSON serializado)
  toolName        String?
  toolInput       Json?
  toolUseId       String?
  attachmentsJson Json?    /// array de ChatAttachmentRef
  createdAt       DateTime @default(now())

  conversation FactoryChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// =====================================================================
// FactoryNotification — eventos visibles para el operador en /factory.
//
// Se persisten cuando ocurre algo relevante en el negocio (alta,
// pago, trial expira, fallo de pago, error de webhook, etc.) para
// que el operador (Jorge) pueda verlos sin entrar a logs.
//
// `severity` determina el color del badge: info / success / warning /
// error. `readAt` permite distinguir leídos de pendientes para la
// campanita.
// =====================================================================
model FactoryNotification {
  id        String    @id
  type      String    // alta_created | payment_received | trial_expiring | trial_expired | payment_failed | tenant_cancelled | webhook_error | manual
  severity  String    // info | success | warning | error
  title     String
  message   String
  // Datos contextuales (slug del tenant, importe, plan, etc.)
  metadata  Json?
  // Cuándo se marcó como leído (null = pendiente)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([readAt, createdAt])
  @@index([type, createdAt])
}

// =====================================================================
// HORIZONTE 3 — modelos de plataforma
// =====================================================================

/// H3-ARQ-01 — Background jobs queue en Postgres.
/// Procesa: emails diferidos, recálculo de KPIs, retry envíos AEAT.
/// Worker: /api/cron/tick (Vercel Cron cada minuto).
model BackgroundJob {
  id          String   @id @default(cuid())
  tenantId    String?
  clientId    String?
  /// kind: email | recalc-kpis | verifactu-resend | gdpr-export | custom
  kind        String
  payloadJson Json
  /// status: pending | running | done | failed
  status      String   @default("pending")
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  /// Earliest time the job can be processed (delays / backoff).
  runAfter    DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  errorMsg    String?
  createdAt   DateTime @default(now())

  @@index([status, runAfter])
  @@index([clientId, kind, status])
}

/// H3-GDPR-02 — Política de retención por tenant.
/// Aplica a AuditEvent y FactoryNotification. Default: 365 días.
model TenantLogPolicy {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  clientId      String   @unique
  retentionDays Int      @default(365)
  updatedAt     DateTime @updatedAt
}

/// H10-D — Vistas guardadas por usuario y módulo.
model TenantSavedView {
  id         String   @id @default(cuid())
  tenantId   String
  clientId   String
  userEmail  String
  moduleKey  String
  name       String
  /// JSON con filtros + columnas + orden + densidad
  configJson Json
  esDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([clientId, userEmail, moduleKey])
}

/// H10-F — Comentarios por registro.
model TenantRecordComment {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  moduleKey   String
  recordId    String
  authorEmail String
  body        String
  /// Lista de emails mencionados con @
  mentions    String[]
  parentId    String?  // para threads
  createdAt   DateTime @default(now())

  @@index([clientId, moduleKey, recordId, createdAt])
}

/// H8-C1 — Punto de venta / sede de un cliente. Un cliente puede tener
/// N puntos (sucursales, almacenes, oficinas). Cada uno con su código,
/// dirección y tipo. Es el modelo Empresa+Puntos de Cliens.
model TenantClientLocation {
  id           String   @id @default(cuid())
  tenantId     String
  clientId     String
  /// id del registro de cliente al que pertenece (TenantModuleRecord.id de moduleKey=clientes)
  parentClienteId String
  codigo       String
  nombre       String
  direccion    String?
  ciudad       String?
  zona         String?
  tipoCliente  String?  // administracion | distribuidor | gestion | proveedor | final
  email        String?
  telefono     String?
  estado       String   @default("activo") // activo | inactivo
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId, parentClienteId])
  @@index([clientId, codigo])
}

/// H8-S1 — Tipos de contrato de mantenimiento (estilo SISPYME Mant.
/// Nivel 1, 2, 3, 4, Cuota Axis, Mant. a medida X). Cada tipo define
/// llamadas/mes, exceso, urgencias, recargo nocturno, horas/año,
/// desplazamiento y tarifa €/h por tipo de servicio.
model TenantContractType {
  id                    String   @id @default(cuid())
  tenantId              String
  clientId              String
  codigo                String
  nombre                String
  llamadasPermitidasMes Int      @default(0)
  precioExcesoLlamada   Float    @default(0)
  cambiosUrgPermitidos  Int      @default(0)
  precioCambioNorUrg    Float    @default(0)
  precioCambioUrgMU     Float    @default(0)
  recargoFueraHorarioPct Float   @default(0)
  horasContratadas      Float    @default(0)
  periodicidadHoras     String   @default("ANUAL") // MENSUAL | TRIMESTRAL | ANUAL
  desplPrecioFijo       Float    @default(0)
  desplPrecioKm         Float    @default(0)
  /// JSON: { "Análisis, Consulting": 75, "Programación": 61, "Soporte a usuario, explotación": 55, ... }
  tarifasPorTipoServicio Json    @default("{}")
  estado                String   @default("activo") // activo | obsoleto
  notas                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([clientId, codigo])
  @@index([clientId, estado])
}

/// H8-C9 — Periodos cerrados. Una vez cerrado, las actividades y
/// facturas del periodo no se pueden modificar.
model TenantClosedPeriod {
  id         String   @id @default(cuid())
  tenantId   String
  clientId   String
  ejercicio  Int
  mes        Int      // 1-12
  cerradoAt  DateTime @default(now())
  cerradoPor String
  notas      String?

  @@unique([clientId, ejercicio, mes])
  @@index([clientId, ejercicio])
}

/// H7-C4 — Sociedades del tenant. Un mismo tenant puede tener varias
/// razones sociales que facturan al mismo cliente desde distintos CIF.
/// Ejemplo: HSM y SISPYME conviven en el grupo, distinta facturación.
model TenantCompany {
  id              String   @id @default(cuid())
  tenantId        String
  clientId        String
  razonSocial     String
  cif             String
  iban            String?
  direccion       String?
  email           String?
  telefono        String?
  esEmisorPorDefecto Boolean @default(false)
  estado          String   @default("activa") // activa | inactiva
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId, estado])
}

/// H6-PSD2 — Movimiento bancario importado vía agregador PSD2.
/// Idempotente por (clientId, externalId) para no duplicar al refrescar.
model BankMovement {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  /// id externo del agregador (ej. Fintecture transactionId)
  externalId  String
  account     String?  // IBAN o ID interno de cuenta
  date        DateTime
  amountEur   Float
  description String
  /// "credit" (entrada) | "debit" (salida)
  direction   String
  matchedFacturaId String?
  matchedAt   DateTime?
  rawJson     Json?
  createdAt   DateTime @default(now())

  @@unique([clientId, externalId])
  @@index([clientId, date])
  @@index([clientId, matchedFacturaId])
}

/// H6-VERIFACTU-SIGN — Certificado digital del tenant para firmar XML
/// Verifactu. Cifrado con crypto-vault (AES-GCM) antes de persistir.
model TenantCertificate {
  id           String   @id @default(cuid())
  tenantId     String
  clientId     String   @unique
  /// "fnmt" | "ac-camerfirma" | "izenpe" | "otro"
  issuer       String?
  /// PEM concatenado: cert + intermediate (cifrado)
  certPem      String
  /// Clave privada PEM (cifrado)
  keyPem       String
  /// Para mostrar al usuario sin descifrar
  subject      String?
  validFrom    DateTime?
  validUntil   DateTime?
  uploadedAt   DateTime @default(now())
}

/// H6-PDF-EDITOR — Plantilla PDF personalizada del tenant.
model TenantPdfTemplate {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String   @unique
  logoUrl       String?
  primaryColor  String   @default("#1d4ed8")
  pieFactura    String?
  mensajePie    String?
  mostrarBancos Boolean  @default(true)
  iban          String?
  updatedAt     DateTime @updatedAt
}

/// H6-PAY-LINK — Sesiones de Stripe Checkout creadas para cobrar a
/// clientes finales (independiente de la suscripción del tenant).
model TenantPayLink {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  facturaId   String?
  amountEur   Float
  concept     String
  email       String?
  stripeSession String   @unique
  url         String
  status      String   @default("pending") // pending | paid | expired
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([clientId, status, createdAt])
}

/// H5-UX-02 — Widgets configurables del dashboard del tenant.
model TenantDashboardWidget {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String
  /// kind: kpi | counter | list | chart
  kind      String
  /// configuración del widget (moduleKey, label, query, color, etc.)
  configJson Json
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, position])
}

/// H5-OPS-01 — Snapshots periódicos del health check para mostrar
/// uptime histórico en la status page pública.
model HealthSnapshot {
  id        String   @id @default(cuid())
  /// overall: ok | degraded | down
  overall   String
  /// detalle por componente (resumido — no guardamos durations)
  componentsJson Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// H4-WF-PRO — Aprobaciones de pasos de workflow multi-paso.
/// Cada fila representa una decisión (approve/reject) sobre un step
/// concreto de una regla.
model WorkflowApproval {
  id        String   @id @default(cuid())
  ruleId    String
  tenantId  String
  clientId  String
  /// id del registro disparador (TenantModuleRecord.id)
  triggerRecordId String
  /// índice del step dentro de actionPayload.steps[]
  stepIndex Int
  /// email del aprobador, o "auto" si fue automático
  decidedBy String
  /// approve | reject
  decision  String
  comment   String?
  createdAt DateTime @default(now())

  @@index([ruleId, triggerRecordId, stepIndex])
  @@index([clientId, createdAt])
}

/// H3-FUNC-04 — Mensajería interna en tiempo real (SSE).
model InternalMessage {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String
  fromEmail String
  toEmail   String?  // null = broadcast a todo el tenant
  subject   String?
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([clientId, toEmail, createdAt])
  @@index([clientId, fromEmail, createdAt])
}

/// H3-FUNC-05 — Estado de integraciones por tenant.
model TenantIntegration {
  id           String   @id @default(cuid())
  tenantId     String
  clientId     String
  /// provider: stripe | google-calendar | whatsapp | mailchimp | slack | zapier
  provider     String
  enabled      Boolean  @default(false)
  /// Datos de configuración (api keys, webhook urls, etc.). Cifrar antes de
  /// guardar usando crypto-vault si contiene secretos.
  configJson   Json     @default("{}")
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([clientId, provider])
  @@index([clientId, enabled])
}
